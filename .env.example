# Optional public API origin used by the browser. Defaults to the local API.
NEXT_PUBLIC_API_URL=http://localhost:8787

# Local-only ports. In production, deploy the web and API as separate services.
WEB_PORT=3000
API_PORT=8787

# Durable local scan database.
PULSE_DATABASE_PATH=.data/asp-pulse.sqlite

# Required for Vercel. Provision a Postgres database (for example Neon through
# the Vercel Marketplace) and set this server-only value in Vercel — never in
# NEXT_PUBLIC_* variables or Git.
DATABASE_URL=

# Real payments remain off. Do not enable without an approved payment adapter.
ENABLE_PAID_CANARY=false
CANARY_DAILY_BUDGET_ATOMIC=0
CANARY_PER_CALL_LIMIT_ATOMIC=0
CANARY_ALLOWLIST=
