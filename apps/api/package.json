  },
  "dependencies": {
    "@asp-pulse/core": "0.1.0",
    "@hono/node-server": "2.0.8",
    "@neondatabase/serverless": "^1.1.0",
    "hono": "4.12.30",
    "undici": "8.7.0"
  }
